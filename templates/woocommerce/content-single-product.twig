{# Single product layout — owned by the theme.
   Each {{ function('do_action', '...') }} call re-emits WC's standard hook
   stack, so plugins (reviews, upsells, related, Stripe, etc.) still wire in.
   Reorder, wrap, or split the columns as needed.

   Hook reference (priorities of WC's defaults):
   - woocommerce_before_single_product_summary:
       10 woocommerce_show_product_sale_flash
       20 woocommerce_show_product_images
   - woocommerce_single_product_summary:
        5 woocommerce_template_single_title
       10 woocommerce_template_single_rating
       10 woocommerce_template_single_price
       20 woocommerce_template_single_excerpt
       30 woocommerce_template_single_add_to_cart
       40 woocommerce_template_single_meta
       50 woocommerce_template_single_sharing
   - woocommerce_after_single_product_summary:
       10 woocommerce_output_product_data_tabs
       15 woocommerce_upsell_display
       20 woocommerce_output_related_products
#}

{{ function('do_action', 'woocommerce_before_single_product') }}

<article class="singleProduct {{ productClasses }} max-w-screen-max mx-auto">
  <div class="singleProduct__layout flex flex-col md:flex-row-reverse gap-sm px-xs py-md pt-[10vw] md:pt-[160px]">
    <div class="singleProduct__media w-full md:w-2/3">
      {{ function('do_action', 'woocommerce_before_single_product_summary') }}
    </div>

    <div class="singleProduct__summary w-full md:w-1/3 entry-summary flex flex-col gap-lg">
      {{ function('do_action', 'woocommerce_single_product_summary') }}
      <div class="singleProduct__extras">
        {{ function('do_action', 'woocommerce_after_single_product_summary') }}
      </div>
    </div>
  </div>

  {% if post.meta('productComponents') %}
    <div class="singleProduct__productComponents mt-lg">
      {% for component in post.meta('productComponents') %}
        {{ renderComponent(component) }}
      {% endfor %}
    </div>
  {% endif %}

  <div class="singleProduct__related mt-lg px-xs py-md">
    {{ function('woocommerce_output_related_products') }}
  </div>
</article>

{{ function('do_action', 'woocommerce_after_single_product') }}
